<Window x:Class="VoidStrike.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:VoidStrike.ViewModels"
        xmlns:converters="clr-namespace:VoidStrike.Converters"
        xmlns:gif="http://wpfanimatedgif.codeplex.com"
        mc:Ignorable="d"
        Title="VoidStrike" Height="850" Width="1300"
        Background="Transparent" WindowStyle="None" AllowsTransparency="True"
        WindowStartupLocation="CenterScreen" MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.DataContext>
        <viewModels:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <converters:EqualValueToVisibilityConverter x:Key="EqualValueToVisibilityConverter" />

        <Style x:Key="NavButton" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#555555"/>
            <Setter Property="Width" Value="180"/>
            <Setter Property="Height" Value="85"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border Background="{TemplateBinding Background}" x:Name="border" BorderThickness="0,0,0,4" BorderBrush="Transparent">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Image Source="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}" Width="26" Height="26" Margin="0,0,0,8" x:Name="img" Opacity="0.85"/>
                                <ContentPresenter HorizontalAlignment="Center">
                                    <ContentPresenter.Resources>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontSize" Value="10"/>
                                            <Setter Property="FontWeight" Value="ExtraBold"/>
                                        </Style>
                                    </ContentPresenter.Resources>
                                </ContentPresenter>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Foreground" Value="White"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="White"/>
                                <Setter TargetName="border" Property="Background" Value="#111111"/>
                                <Setter TargetName="img" Property="Opacity" Value="1"/>
                                <Setter TargetName="img" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect BlurRadius="15" Color="White" Opacity="0.7" ShadowDepth="0"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="img" Property="Opacity" Value="1"/>
                                <Setter TargetName="border" Property="Background" Value="#08FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CyberCheck" TargetType="CheckBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Margin" Value="0,8"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
    </Window.Resources>

    <Border Background="#0A0A0A" Opacity="0.99" CornerRadius="0" BorderBrush="#15FFFFFF" BorderThickness="1">
        <Grid>
            <Image gif:ImageBehavior.AnimatedSource="pack://application:,,,/Resources/12345678.gif" Stretch="UniformToFill" Opacity="0.4"/>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="60"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="85"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="25,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="●●" Foreground="#222222" Margin="0,0,15,0" FontSize="12"/>
                        <TextBlock Text="VOIDSTRIKE" Foreground="White" FontSize="16" FontWeight="Black"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Content="_" Click="Minimize_Click" Foreground="White" Background="Transparent" BorderThickness="0" FontSize="20" Margin="0,0,15,0" Opacity="0.3"/>
                        <Button Content="✕" Click="Close_Click" Foreground="White" Background="Transparent" BorderThickness="0" FontSize="20" Opacity="0.3"/>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1">
                    <Grid Visibility="{Binding CurrentView, Converter={StaticResource EqualValueToVisibilityConverter}, ConverterParameter='Dashboard'}">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="WELCOME" Foreground="#111111" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                            <TextBlock Text="TO VOIDSTRIKE" Foreground="White" FontSize="82" FontWeight="Black" HorizontalAlignment="Center">
                                <TextBlock.Effect>
                                    <DropShadowEffect BlurRadius="50" Color="White" Opacity="0.1"/>
                                </TextBlock.Effect>
                            </TextBlock>
                        </StackPanel>
                    </Grid>

                    <Grid Visibility="{Binding CurrentView, Converter={StaticResource EqualValueToVisibilityConverter}, ConverterParameter='Scanner'}" Margin="40,20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="140"/>
                        </Grid.RowDefinitions>

                        <Border Background="#05FFFFFF" BorderBrush="#10FFFFFF" BorderThickness="1" Padding="20,15" Margin="0,0,0,25">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Text="{Binding TargetUrl, UpdateSourceTrigger=PropertyChanged}" Background="Transparent" Foreground="White" BorderThickness="0" FontSize="18" VerticalContentAlignment="Center" CaretBrush="White"/>
                                <Button Grid.Column="1" Command="{Binding StartScanCommand}" Content="LAUNCH STRIKE" Background="White" Foreground="Black" Padding="40,10" FontWeight="Black" FontSize="11"/>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="320"/>
                            </Grid.ColumnDefinitions>

                            <Border Background="#03FFFFFF" BorderBrush="#08FFFFFF" BorderThickness="1" Margin="0,0,20,0">
                                <DataGrid ItemsSource="{Binding Vulnerabilities}" Background="Transparent" Foreground="White" BorderThickness="0" AutoGenerateColumns="False" IsReadOnly="True" RowHeight="50" GridLinesVisibility="None" RowBackground="Transparent" AlternatingRowBackground="Transparent" CanUserAddRows="False">
                                    <DataGrid.Resources>
                                        <Style TargetType="DataGridColumnHeader">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="FontWeight" Value="ExtraBold"/>
                                            <Setter Property="Padding" Value="10"/>
                                            <Setter Property="FontSize" Value="11"/>
                                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                            <Setter Property="BorderBrush" Value="#22FFFFFF"/>
                                        </Style>
                                        <Style TargetType="DataGridCell">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="DataGridCell">
                                                        <Border Background="Transparent">
                                                            <ContentPresenter VerticalAlignment="Center" Margin="10,0"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                        <Style TargetType="DataGridRow">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="#15FFFFFF"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.Resources>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="SEVERITY" Binding="{Binding Severity}" Width="100"/>
                                        <DataGridTextColumn Header="TYPE" Binding="{Binding Type}" Width="250"/>
                                        <DataGridTextColumn Header="ENDPOINT" Binding="{Binding Url}" Width="*"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Border>

                            <Border Grid.Column="1" Background="#03FFFFFF" BorderBrush="#08FFFFFF" BorderThickness="1" Padding="25">
                                <StackPanel>
                                    <TextBlock Text="ATTACK PARAMETERS" Foreground="#222222" FontSize="10" FontWeight="Bold" Margin="0,0,0,20"/>
                                    <CheckBox Content="SQL Injection" Style="{StaticResource CyberCheck}"/>
                                    <CheckBox Content="Cross Site Scripting" Style="{StaticResource CyberCheck}"/>
                                    <CheckBox Content="Command Injection" Style="{StaticResource CyberCheck}" IsChecked="True"/>
                                    <CheckBox Content="LFI / RCE" Style="{StaticResource CyberCheck}"/>
                                    <CheckBox Content="JWT Security" Style="{StaticResource CyberCheck}" IsChecked="True"/>
                                    <CheckBox Content="Full Discovery" Style="{StaticResource CyberCheck}" IsChecked="True"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border Grid.Row="2" Background="#02FFFFFF" BorderBrush="#08FFFFFF" BorderThickness="1" Margin="0,20,0,0">
                            <ScrollViewer>
                                <ItemsControl ItemsSource="{Binding ScanLogs}" Margin="15">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" Foreground="White" Opacity="0.8" FontSize="11" FontFamily="Consolas" Margin="0,2"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Border>
                    </Grid>

                    <Grid Visibility="{Binding CurrentView, Converter={StaticResource EqualValueToVisibilityConverter}, ConverterParameter='About'}">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <Image Source="pack://application:,,,/1382932704445595678.ico" Width="120" Height="120" Opacity="0.9"/>
                            <TextBlock Text="VOIDSTRIKE" Foreground="White" FontSize="62" FontWeight="Black" Margin="0,15,0,0"/>
                            <TextBlock Text="DEVELOPED BY MKAF7H" Foreground="#222222" FontSize="13" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,30"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button Content="DISCORD" Background="Transparent" BorderBrush="#15FFFFFF" BorderThickness="1" Foreground="White" Padding="35,10" Margin="0,0,10,0" FontSize="10" FontWeight="Bold"/>
                                <Button Content="GITHUB" Background="Transparent" BorderBrush="#15FFFFFF" BorderThickness="1" Foreground="White" Padding="35,10" FontSize="10" FontWeight="Bold"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Grid>

                <Border Grid.Row="2" Background="#050505" BorderBrush="#10FFFFFF" BorderThickness="0,1,0,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <RadioButton Content="DASHBOARD" IsChecked="True" Style="{StaticResource NavButton}"
                                     Command="{Binding ChangeViewCommand}" CommandParameter="Dashboard"
                                     Tag="pack://application:,,,/dashboard.png"/>

                        <RadioButton Content="STRIKE ENGINE" Style="{StaticResource NavButton}"
                                     Command="{Binding ChangeViewCommand}" CommandParameter="Scanner"
                                     Tag="pack://application:,,,/scaner.png"/>

                        <RadioButton Content="SYSTEM INFO" Style="{StaticResource NavButton}"
                                     Command="{Binding ChangeViewCommand}" CommandParameter="About"
                                     Tag="pack://application:,,,/about.png"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
